DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/oci_migration
REDIS_URL=redis://localhost:6379

# LLM endpoint — OpenAI-compatible chat completions URL. Default is the
# Oracle internal Llama Stack gateway (anonymous, no API key). Can be
# swapped to OCI Generative AI, OpenAI, vLLM, etc. via the Settings UI
# or by overriding LLM_BASE_URL here.
LLM_BASE_URL=https://llama-stack.ai-apps-ord.oci-incubations.com/v1
LLM_API_KEY=

# Default models. Runtime overrides live in the system_settings DB table
# (change via the frontend Settings → LLM Models page). Any ID returned
# by GET /api/settings/models works here.
LLM_WRITER_MODEL=oci/openai.gpt-5.4
LLM_REVIEWER_MODEL=oci/openai.gpt-5.4-mini

JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440
